import os
import sys
from PyQt6.QtWidgets import (QMainWindow, QTabWidget, QWidget, QVBoxLayout, QHBoxLayout, 
                             QPushButton, QLineEdit, QLabel, QProgressBar, QComboBox, 
                             QTableWidget, QTableWidgetItem, QHeaderView, QFileDialog,
                             QMessageBox, QCheckBox, QTextEdit, QListWidget, QListWidgetItem)
from PyQt6.QtCore import Qt, pyqtSignal, QThread
from PyQt6.QtGui import QFont

sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from core.downloader import Downloader
from core.tagger import Tagger
# from core.nicotine_integration import P2PManager  # Disabled for debugging
from core.themes import get_stylesheet, get_theme_names
import config

class DownloadThread(QThread):
    progress = pyqtSignal(float)
    status = pyqtSignal(str)
    finished = pyqtSignal()
    
    def __init__(self, url, audio_format, quality, cookies, embed_metadata=True, embed_lyrics=False):
        super().__init__()
        self.url = url
        self.audio_format = audio_format
        self.quality = quality
        self.cookies = cookies
        self.embed_metadata = embed_metadata
        self.embed_lyrics = embed_lyrics
        self.downloader = None
    
    def run(self):
        self.downloader = Downloader(
            progress_callback=self.progress.emit,
            status_callback=self.status.emit
        )
        # Override download_tracks_threaded to pass metadata/lyrics flags
        self._download_with_options()
        self.finished.emit()
    
    def _download_with_options(self):
        """Download tracks with metadata/lyrics options"""
        def download_thread():
            tracks = self.downloader.get_tracks_from_url(self.url)
            if not tracks:
                if self.downloader.status_callback:
                    self.downloader.status_callback("No tracks found")
                return
            
            os.makedirs(config.DOWNLOAD_DIR, exist_ok=True)
            
            for i, track in enumerate(tracks, 1):
                if self.downloader.status_callback:
                    self.downloader.status_callback(f"[{i}/{len(tracks)}] {track['name']} - {track['artist']}")
                success, msg = self.downloader.download_track(
                    track, config.DOWNLOAD_DIR, 
                    self.audio_format, self.quality, 
                    self.cookies, self.embed_metadata, self.embed_lyrics
                )
                if not success and self.downloader.status_callback:
                    self.downloader.status_callback(f"Failed: {msg}")
        
        thread = threading.Thread(target=download_thread)
        thread.daemon = True
        thread.start()
        # Don't join - let it run in background


class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.downloader = Downloader(
            progress_callback=self.update_progress,
            status_callback=self.update_status
        )
        self.init_ui()
        # self.load_files()  # Commented out for debugging
    
    def init_ui(self):
        print("init_ui started...", file=sys.stderr)
        self.setWindowTitle("NexusAudio - Downloader & Tag Editor")
        self.setGeometry(100, 100, 1200, 800)
        
        print("Creating tabs widget...", file=sys.stderr)
        # Central widget with tabs
        self.tabs = QTabWidget()
        self.setCentralWidget(self.tabs)
        
        # Set current theme BEFORE creating tabs
        print("Setting theme...", file=sys.stderr)
        self.current_theme = config.THEME if hasattr(config, 'THEME') else 'Nexus Dark'
        
        # Create all tabs
        print("Creating Downloader tab...", file=sys.stderr)
        self.downloader_widget = QWidget()
        self.tabs.addTab(self.downloader_widget, "Downloader")
        self.init_downloader_tab()
        
        print("Creating Tag Editor tab...", file=sys.stderr)
        self.tagger_widget = QWidget()
        self.tabs.addTab(self.tagger_widget, "Tag Editor")
        self.init_tagger_tab()
        
        print("Creating P2P tab...", file=sys.stderr)
        self.p2p_widget = QWidget()
        self.tabs.addTab(self.p2p_widget, "P2P (Soulseek)")
        self.init_p2p_tab()
        
        print("Creating Settings tab...", file=sys.stderr)
        self.settings_widget = QWidget()
        self.tabs.addTab(self.settings_widget, "Settings")
        self.init_settings_tab()
        
        # Apply default theme after tabs are created
        print("Applying theme...", file=sys.stderr)
        self.apply_theme(self.current_theme)
    
    def apply_theme(self, theme_name):
        print(f"Applying theme: {theme_name}...", file=sys.stderr)
        self.current_theme = theme_name
        try:
            stylesheet = get_stylesheet(theme_name)
            self.setStyleSheet(stylesheet)
            print("Theme applied!", file=sys.stderr)
        except Exception as e:
            print(f"Theme error: {e}", file=sys.stderr)
        
        # Downloader tab
        self.downloader_widget = QWidget()
        self.tabs.addTab(self.downloader_widget, "Downloader")
        self.init_downloader_tab()
        
        # Tag Editor tab (puddletag style)
        self.tagger_widget = QWidget()
        self.tabs.addTab(self.tagger_widget, "Tag Editor")
        self.init_tagger_tab()
        
        # P2P Tab (Soulseek/Nicotine+ based)
        self.p2p_widget = QWidget()
        self.tabs.addTab(self.p2p_widget, "P2P (Soulseek)")
        self.init_p2p_tab()
        
        # Settings tab
        self.settings_widget = QWidget()
        self.tabs.addTab(self.settings_widget, "Settings")
        self.init_settings_tab()
        
        # Initialize P2P manager (integrated Soulseek functionality) - disabled for now
        self.p2p_manager = None
    
    def init_downloader_tab(self):
        layout = QVBoxLayout()
        
        # URL input
        url_layout = QHBoxLayout()
        url_label = QLabel("Spotify URL:")
        self.url_input = QLineEdit()
        self.url_input.setPlaceholderText("https://open.spotify.com/track/... or /playlist/...")
        url_layout.addWidget(url_label)
        url_layout.addWidget(self.url_input)
        layout.addLayout(url_layout)
        
        # Options row
        options_layout = QHBoxLayout()
        
        # Format selection
        format_label = QLabel("Format:")
        self.format_combo = QComboBox()
        self.format_combo.addItems(['mp3', 'flac', 'm4a', 'ogg'])
        self.format_combo.currentTextChanged.connect(self.update_quality_options)
        options_layout.addWidget(format_label)
        options_layout.addWidget(self.format_combo)
        
        # Quality selection
        quality_label = QLabel("Quality:")
        self.quality_combo = QComboBox()
        self.quality_combo.addItems(['64', '128', '192', '256', '320'])
        self.quality_combo.setCurrentText('192')
        options_layout.addWidget(quality_label)
        options_layout.addWidget(self.quality_combo)
        
        # Cookies option
        cookies_label = QLabel("Cookies:")
        self.cookies_combo = QComboBox()
        self.cookies_combo.addItems(['firefox', 'chrome', 'chromium', 'brave', 'edge', 'safari', 'none'])
        self.cookies_combo.setCurrentText(config.COOKIES_BROWSER)
        options_layout.addWidget(cookies_label)
        options_layout.addWidget(self.cookies_combo)
        
        options_layout.addStretch()
        layout.addLayout(options_layout)
        
        # Download button
        self.download_btn = QPushButton("Download")
        self.download_btn.clicked.connect(self.start_download)
        layout.addWidget(self.download_btn)
        
        # Progress bar
        self.progress_bar = QProgressBar()
        self.progress_bar.setRange(0, 100)
        self.progress_bar.setValue(0)
        layout.addWidget(self.progress_bar)
        
        # Status label
        self.status_label = QLabel("Ready")
        layout.addWidget(self.status_label)
        
        layout.addStretch()
        self.downloader_widget.setLayout(layout)
    
    def init_tagger_tab(self):
        layout = QVBoxLayout()
        
        # Buttons row
        btn_layout = QHBoxLayout()
        refresh_btn = QPushButton("Refresh Files")
        refresh_btn.clicked.connect(self.load_files)
        rename_btn = QPushButton("Rename: Artist - Title")
        rename_btn.clicked.connect(self.rename_files)
        btn_layout.addWidget(refresh_btn)
        btn_layout.addWidget(rename_btn)
        btn_layout.addStretch()
        layout.addLayout(btn_layout)
        
        # Table (spreadsheet interface)
        self.table = QTableWidget()
        self.table.setColumnCount(7)
        self.table.setHorizontalHeaderLabels(['File', 'Title', 'Artist', 'Album', 'Genre', 'Year', 'Track#'])
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
        self.table.cellChanged.connect(self.on_cell_changed)
        layout.addWidget(self.table)
        
        self.tagger_widget.setLayout(layout)
    
    def init_p2p_tab(self):
        layout = QVBoxLayout()
        
        # Connection status (read-only display)
        conn_layout = QHBoxLayout()
        conn_layout.addWidget(QLabel("Status:"))
        self.p2p_status_label = QLabel("Disconnected")
        conn_layout.addWidget(self.p2p_status_label)
        
        self.connect_btn = QPushButton("Connect")
        self.connect_btn.clicked.connect(self.toggle_p2p_connection)
        conn_layout.addWidget(self.connect_btn)
        conn_layout.addStretch()
        layout.addLayout(conn_layout)
    
